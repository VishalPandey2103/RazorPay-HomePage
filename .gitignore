# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore node modules
node_modules/

# Ignore build and dependency directories
dist/
build/
out/

# Ignore logs
*.log

# Ignore environment files
.env
.env.local

# Ignore compiled code
*.class
*.o
*.so
*.exe

# Ignore IDE/editor settings
.vscode/
.idea/
*.swp

# Ignore Python cache
__pycache__/
*.pyc
